{
  "name": "open-resume",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --watch",
    "test:ci": "jest --ci",
    "setup-electron": "node setup-electron.js",
    "electron-dev": "concurrently \"npm run dev\" \"electron .\"",
    "electron": "wait-on http://localhost:3000 && electron .",
    "pack": "electron-builder --dir",
    "dist": "next build && electron-builder"
  },
  "main": "main.js",
  "build": {
    "appId": "com.resumetojob.app",
    "productName": "ResumeToJob",
    "files": [
      "main.js",
      "preload.js",
      ".next/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@heroicons/react": "^2.0.18",
    "@react-pdf/renderer": "^3.1.10",
    "@reduxjs/toolkit": "^1.9.5",
    "@types/node": "20.2.5",
    "@types/react": "18.2.7",
    "@types/react-dom": "18.2.4",
    "@vercel/analytics": "^1.0.1",
    "autoprefixer": "10.4.14",
    "eslint": "8.41.0",
    "eslint-config-next": "13.4.4",
    "framer-motion": "^10.12.16",
    "next": "13.4.4",
    "pdfjs": "^2.5.0",
    "pdfjs-dist": "^3.7.107",
    "postcss": "8.4.24",
    "react": "18.2.0",
    "react-contenteditable": "^3.3.7",
    "react-dom": "18.2.0",
    "react-frame-component": "^5.2.6",
    "react-redux": "^8.0.7",
    "tailwind-scrollbar": "^3.0.4",
    "tailwindcss": "3.3.2",
    "typescript": "5.0.4"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^14.0.0",
    "concurrently": "^8.2.0",
    "electron": "^25.2.0",
    "electron-builder": "^24.4.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "prettier-plugin-tailwindcss": "^0.2.1",
    "wait-on": "^7.0.1"
  }
}
